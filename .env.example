# ── Google Cloud credentials ──────────────────────────────────────────────────
# Option A (recommended on Cloud Run): leave blank and assign a service account
#   to the Cloud Run service via --service-account flag.
# Option B (local dev / other platforms): paste the full service account JSON.
GCS_CREDENTIALS_JSON=


# GCP project and Vertex AI region
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1

# ── Google Cloud Storage ──────────────────────────────────────────────────────
GCS_BUCKET_NAME=your-bucket-name

# "true"  → public https:// URLs  (bucket needs allUsers objectViewer)
# "false" → signed URLs valid 1 h  (bucket can be private)
GCS_PUBLIC_BUCKET=false

# ── Server ────────────────────────────────────────────────────────────────────
# Cloud Run sets PORT automatically; uncomment for local override
# PORT=8080
WORKER_THREADS=8
